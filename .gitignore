# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Do NOT commit the lockfile: it is generated per-OS and a Windows-built
# lockfile breaks Linux CI builds (npm optional native-binary bug #4828).
# Without it, Coolify runs a fresh `npm install` on Linux with correct binaries.
package-lock.json

# Env — do not commit local env (use .env.example)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
