# Barcode frontend → backend API base URL
#
# Local dev:   backend runs on :5001
#   VITE_API_BASE_URL=http://localhost:5001/api
#
# Production (Coolify): set this to the deployed backend URL + /api.
# NOTE: Vite bakes this in at BUILD time, so it must be set as a
# BUILD variable in Coolify (not just a runtime env var).
#   VITE_API_BASE_URL=http://wef407vl1aqzgq4uz3pqy8xl.151.158.101.246.sslip.io/api

VITE_API_BASE_URL=http://localhost:5001/api
